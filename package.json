{
  "name": "job-runner",
  "version": "1.0.0",
  "private": true,
  "description": "SSE Job Runner PoC - Real-time job progress streaming via Server-Sent Events",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build:shared": "pnpm --filter @job-runner/shared build",
    "build:server": "pnpm --filter @job-runner/server build",
    "build:dashboard": "pnpm --filter @job-runner/dashboard build",
    "build": "pnpm build:shared && pnpm build:server"
  }
}
